@@ -0,0 +1,55 @@
+import { UserCheck, Users } from "lucide-react";
+import { cn } from "../lib/utils";
+import type { IssueDecisionState } from "../lib/pendingDecisions";
+
+/**
+ * KIN-4780 (Better Actions Phase 3 UI). The pending-decision row badge shown on
+ * issue list rows and the issue detail header.
+ *
+ * Precedence: a decision bound to me ("Waiting on you") implies the issue is
+ * also awaiting the board, so when both are true we show only the stronger,
+ * personal badge. The personal badge uses a deliberately distinct colour
+ * (violet) from plain assignment chips (status/amber) so "a decision is waiting
+ * on *me*" reads differently from "this task is assigned to me".
+ */
+export function IssueDecisionBadge({
+  awaitingMe,
+  awaitingBoard,
+  className,
+}: IssueDecisionState & { className?: string }) {
+  if (awaitingMe) {
+    return (
+      <span
+        className={cn(
+          "ml-1.5 inline-flex items-center gap-1 rounded-full border px-1.5 py-0.5 text-[10px] font-medium",
+          "border-violet-500/40 bg-violet-500/10 text-violet-700 dark:text-violet-300",
+          className,
+        )}
+        aria-label="Waiting on you — a decision on this task is yours to make"
+        title="Waiting on you — a decision on this task is yours to make"
+        data-testid="waiting-on-you-approver-badge"
+      >
+        <UserCheck className="h-3 w-3" />
+        Waiting on you
+      </span>
+    );
+  }
+  if (awaitingBoard) {
+    return (
+      <span
+        className={cn(
+          "ml-1.5 inline-flex items-center gap-1 rounded-full border px-1.5 py-0.5 text-[10px] font-medium",
+          "border-sky-500/40 bg-sky-500/10 text-sky-700 dark:text-sky-300",
+          className,
+        )}
+        aria-label="Awaiting a board decision"
+        title="Awaiting a board decision"
+        data-testid="awaiting-board-chip"
+      >
+        <Users className="h-3 w-3" />
+        Awaiting board
+      </span>
+    );
+  }
+  return null;
+}
