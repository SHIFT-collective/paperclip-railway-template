index 0000000..6eb2a9f
--- /dev/null
+++ b/ui/src/lib/pendingDecisions.test.ts
@@ -0,0 +1,86 @@
+// @vitest-environment node
+
+import { describe, expect, it } from "vitest";
+import type { PendingInteraction } from "@paperclipai/shared";
+import { buildPendingDecisionIndex, issueDecisionStateForUser } from "./pendingDecisions";
+
+const ME = "user-me";
+const OTHER = "user-other";
+
+function pending(issueId: string, responderUserId: string | null): PendingInteraction {
+  return {
+    interaction: { id: `int-${issueId}`, issueId } as PendingInteraction["interaction"],
+    anchor: `interaction-int-${issueId}`,
+    issue: { id: issueId, identifier: issueId, title: "t", status: "in_progress" },
+    requestedByAgent: null,
+    requestedByUserId: null,
+    responderUserId,
+    ageSeconds: 0,
+    target: null,
+  } as PendingInteraction;
+}
+
+describe("buildPendingDecisionIndex", () => {
+  it("treats every pending interaction as awaiting the board, bound or unbound", () => {
+    const index = buildPendingDecisionIndex({
+      pendingInteractions: [pending("a", ME), pending("b", OTHER), pending("c", null)],
+      currentUserId: ME,
+    });
+    expect([...index.awaitingBoardIssueIds].sort()).toEqual(["a", "b", "c"]);
+  });
+
+  it("marks an issue awaiting me only when a decision is bound to me (strict, not unbound)", () => {
+    const index = buildPendingDecisionIndex({
+      pendingInteractions: [pending("a", ME), pending("b", OTHER), pending("c", null)],
+      currentUserId: ME,
+    });
+    // Unbound (c) and someone-else's (b) are NOT "mine"; only the bound-to-me (a) is.
+    expect([...index.awaitingMeIssueIds]).toEqual(["a"]);
+  });
+
+  it("never marks anything as mine when there is no current user", () => {
+    const index = buildPendingDecisionIndex({
+      pendingInteractions: [pending("a", null)],
+      currentUserId: null,
+    });
+    expect(index.awaitingMeIssueIds.size).toBe(0);
+    expect(index.awaitingBoardIssueIds.has("a")).toBe(true);
+  });
+});
+
+describe("issueDecisionStateForUser", () => {
+  it("folds pending interactions and approvals; only pending/revision_requested count", () => {
+    const state = issueDecisionStateForUser({
+      interactions: [
+        { status: "resolved", responderUserId: ME },
+        { status: "pending", responderUserId: OTHER },
+      ],
+      approvals: [
+        { status: "approved", approverUserId: ME },
+        { status: "pending", approverUserId: ME },
+      ],
+      currentUserId: ME,
+    });
+    expect(state.awaitingBoard).toBe(true); // pending interaction + pending approval
+    expect(state.awaitingMe).toBe(true); // the pending approval is bound to me
+  });
+
+  it("is awaiting the board but not me when the only pending decision is unbound", () => {
+    const state = issueDecisionStateForUser({
+      interactions: [{ status: "pending", responderUserId: null }],
+      approvals: [],
+      currentUserId: ME,
+    });
+    expect(state.awaitingBoard).toBe(true);
+    expect(state.awaitingMe).toBe(false);
+  });
+
+  it("returns all-false when nothing is pending", () => {
+    const state = issueDecisionStateForUser({
+      interactions: [{ status: "resolved", responderUserId: ME }],
+      approvals: [{ status: "approved", approverUserId: ME }],
+      currentUserId: ME,
+    });
+    expect(state).toEqual({ awaitingBoard: false, awaitingMe: false });
+  });
+});
diff --git a/ui/src/lib/pendingDecisions.ts b/ui/src/lib/pendingDecisions.ts
new file mode 100644
index 0000000..add045c
--- /dev/null
+++ b/ui/src/lib/pendingDecisions.ts
@@ -0,0 +1,97 @@
+import type { Approval, PendingInteraction } from "@paperclipai/shared";
+
+/**
+ * KIN-4780 (Better Actions Phase 3 UI). Shared, pure helpers that turn the raw
+ * pending-decision surfaces (pending interactions + linked approvals, both now
+ * carrying responder/approver binding from KIN-4701) into the per-issue signals
+ * the UI renders: the "Waiting on you — Approver" badge, the "Needs my decision"
+ * filter, and the derived "Awaiting board" chip.
+ *
+ * Two distinct ideas, kept deliberately separate:
+ *  - **awaitingBoard** — the issue has *any* pending board-facing decision,
+ *    bound to a specific board user or unbound (anyone may decide). This is the
+ *    broad "Awaiting board" chip.
+ *  - **awaitingMe** — a pending decision is bound to the *current* board user
+ *    (`responderUserId`/`approverUserId === currentUserId`). Strictly bound:
+ *    an unbound decision is actionable by everyone but is not "mine". This is
+ *    the "Waiting on you — Approver" badge and the "Needs my decision" filter.
+ */
+
+/** Approval statuses that still need a board decision. Mirrors inbox.ts. */
+export const ACTIONABLE_DECISION_APPROVAL_STATUSES = new Set([
+  "pending",
+  "revision_requested",
+]);
+
+export interface PendingDecisionIndex {
+  /** Issue IDs with any pending board-facing decision (bound or unbound). */
+  awaitingBoardIssueIds: ReadonlySet<string>;
+  /** Issue IDs with a pending decision bound to the current board user. */
+  awaitingMeIssueIds: ReadonlySet<string>;
+}
+
+/**
+ * Build the per-issue index from the company-wide pending-interactions list.
+ * Approvals are not company-listable per issue (the `Approval` type carries no
+ * `issueId`), so list-row badges/filters derive from interactions only; the
+ * issue-detail badge additionally folds in that issue's linked approvals via
+ * {@link issueDecisionStateForUser}.
+ */
+export function buildPendingDecisionIndex({
+  pendingInteractions,
+  currentUserId,
+}: {
+  pendingInteractions: readonly PendingInteraction[];
+  currentUserId?: string | null;
+}): PendingDecisionIndex {
+  const awaitingBoardIssueIds = new Set<string>();
+  const awaitingMeIssueIds = new Set<string>();
+  for (const pending of pendingInteractions) {
+    const issueId = pending.issue?.id;
+    if (!issueId) continue;
+    awaitingBoardIssueIds.add(issueId);
+    if (currentUserId && pending.responderUserId === currentUserId) {
+      awaitingMeIssueIds.add(issueId);
+    }
+  }
+  return { awaitingBoardIssueIds, awaitingMeIssueIds };
+}
+
+export interface IssueDecisionState {
+  /** Any pending board-facing decision on this issue (bound or unbound). */
+  awaitingBoard: boolean;
+  /** A pending decision on this issue is bound to the current board user. */
+  awaitingMe: boolean;
+}
+
+/**
+ * Per-issue decision state from that issue's own pending interactions and
+ * linked approvals — used on the issue detail page, where both are loaded.
+ */
+export function issueDecisionStateForUser({
+  interactions,
+  approvals,
+  currentUserId,
+}: {
+  interactions?: readonly { status: string; responderUserId?: string | null }[];
+  approvals?: readonly Pick<Approval, "status" | "approverUserId">[];
+  currentUserId?: string | null;
+}): IssueDecisionState {
+  let awaitingBoard = false;
+  let awaitingMe = false;
+  for (const interaction of interactions ?? []) {
+    if (interaction.status !== "pending") continue;
+    awaitingBoard = true;
+    if (currentUserId && interaction.responderUserId === currentUserId) {
+      awaitingMe = true;
+    }
+  }
+  for (const approval of approvals ?? []) {
+    if (!ACTIONABLE_DECISION_APPROVAL_STATUSES.has(approval.status)) continue;
+    awaitingBoard = true;
+    if (currentUserId && approval.approverUserId === currentUserId) {
+      awaitingMe = true;
+    }
+  }
+  return { awaitingBoard, awaitingMe };
+}
