+    /**
+     * Pending issue-thread interactions across a company, enriched for the inbox
+     * "Decisions" section: issue context, requesting agent, age, and the plan/document
+     * target for plan-bound confirmations. Interactions on terminal (done/cancelled) or
+     * hidden issues are excluded — those decisions are no longer actionable.
+     *
+     * Note (KIN-4697): responder binding (`responderUserId`) ships in Phase 3. Until then
+     * any board member may decide, so this returns every pending board-facing interaction
+     * in the company regardless of the `responderUserId=me` filter passed by the caller.
+     */
+    listPendingForCompany: async (
+      companyId: string,
+      opts?: { now?: Date },
+    ): Promise<PendingInteraction[]> => {
+      const now = opts?.now ?? new Date();
+      const rows = await db
+        .select({
+          interaction: issueThreadInteractions,
+          issueIdentifier: issues.identifier,
+          issueTitle: issues.title,
+          issueStatus: issues.status,
+          agentId: agents.id,
+          agentName: agents.name,
+        })
+        .from(issueThreadInteractions)
+        .innerJoin(issues, eq(issueThreadInteractions.issueId, issues.id))
+        .leftJoin(agents, eq(issueThreadInteractions.createdByAgentId, agents.id))
+        .where(and(
+          eq(issueThreadInteractions.companyId, companyId),
+          eq(issueThreadInteractions.status, "pending"),
+          notInArray(issues.status, ["done", "cancelled"]),
+          isNull(issues.hiddenAt),
+        ))
+        .orderBy(asc(issueThreadInteractions.createdAt), asc(issueThreadInteractions.id));
+
+      return rows.map((row) => {
+        const interaction = hydrateInteraction(row.interaction);
+        const target =
+          interaction.kind === "request_confirmation"
+          || interaction.kind === "request_checkbox_confirmation"
+            ? interaction.payload.target ?? null
+            : null;
+        const createdAtMs = new Date(interaction.createdAt).getTime();
+        const ageSeconds = Math.max(0, Math.floor((now.getTime() - createdAtMs) / 1000));
+        return {
+          interaction,
+          anchor: `interaction-${interaction.id}`,
+          issue: {
+            id: row.interaction.issueId,
+            identifier: row.issueIdentifier ?? null,
+            title: row.issueTitle,
+            status: row.issueStatus,
+          },
+          requestedByAgent: row.agentId ? { id: row.agentId, name: row.agentName ?? "" } : null,
+          requestedByUserId: interaction.createdByUserId ?? null,
+          ageSeconds,
+          target,
+        } satisfies PendingInteraction;
+      });
+    },
+
