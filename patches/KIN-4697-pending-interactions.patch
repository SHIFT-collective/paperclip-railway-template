diff --git a/server/src/__tests__/pending-interactions.test.ts b/server/src/__tests__/pending-interactions.test.ts
new file mode 100644
index 00000000..38d7db3d
--- /dev/null
+++ b/server/src/__tests__/pending-interactions.test.ts
@@ -0,0 +1,235 @@
+import { randomUUID } from "node:crypto";
+import { afterAll, afterEach, beforeAll, describe, expect, it } from "vitest";
+import {
+  agents,
+  companies,
+  issueThreadInteractions,
+  issues,
+  createDb,
+} from "@paperclipai/db";
+import {
+  getEmbeddedPostgresTestSupport,
+  startEmbeddedPostgresTestDatabase,
+} from "./helpers/embedded-postgres.js";
+import { issueThreadInteractionService } from "../services/issue-thread-interactions.ts";
+
+const embeddedPostgresSupport = await getEmbeddedPostgresTestSupport();
+const describeEmbeddedPostgres = embeddedPostgresSupport.supported ? describe : describe.skip;
+
+if (!embeddedPostgresSupport.supported) {
+  console.warn(
+    `Skipping embedded Postgres pending-interactions tests on this host: ${embeddedPostgresSupport.reason ?? "unsupported environment"}`,
+  );
+}
+
+const confirmationPayload = (target?: Record<string, unknown> | null) => ({
+  version: 1 as const,
+  prompt: "Approve the plan?",
+  ...(target ? { target } : {}),
+});
+
+const questionPayload = () => ({
+  version: 1 as const,
+  questions: [
+    {
+      id: "q1",
+      prompt: "Which option?",
+      selectionMode: "single" as const,
+      options: [{ id: "o1", label: "Yes" }],
+    },
+  ],
+});
+
+describeEmbeddedPostgres("listPendingForCompany", () => {
+  let db!: ReturnType<typeof createDb>;
+  let svc!: ReturnType<typeof issueThreadInteractionService>;
+  let tempDb: Awaited<ReturnType<typeof startEmbeddedPostgresTestDatabase>> | null = null;
+
+  beforeAll(async () => {
+    tempDb = await startEmbeddedPostgresTestDatabase("paperclip-pending-interactions-");
+    db = createDb(tempDb.connectionString);
+    svc = issueThreadInteractionService(db);
+  }, 20_000);
+
+  afterEach(async () => {
+    await db.delete(issueThreadInteractions);
+    await db.delete(issues);
+    await db.delete(agents);
+    await db.delete(companies);
+  });
+
+  afterAll(async () => {
+    await tempDb?.cleanup();
+  });
+
+  it("returns pending board-facing interactions enriched with issue, agent, age, and target", async () => {
+    const companyId = randomUUID();
+    const agentId = randomUUID();
+    const openIssueId = randomUUID();
+    const questionIssueId = randomUUID();
+    const doneIssueId = randomUUID();
+    const hiddenIssueId = randomUUID();
+    const revisionId = randomUUID();
+
+    const confirmationId = randomUUID();
+    const questionId = randomUUID();
+    const acceptedId = randomUUID();
+    const doneIssueInteractionId = randomUUID();
+    const hiddenIssueInteractionId = randomUUID();
+
+    const now = new Date("2026-06-12T12:00:00.000Z");
+    const confirmationCreatedAt = new Date("2026-06-12T11:00:00.000Z"); // 1h old
+    const questionCreatedAt = new Date("2026-06-12T11:30:00.000Z"); // 30m old, created later
+
+    await db.insert(companies).values({
+      id: companyId,
+      name: "Kingdom Kratom",
+      issuePrefix: "KIN",
+      requireBoardApprovalForNewAgents: false,
+    });
+
+    await db.insert(agents).values({
+      id: agentId,
+      companyId,
+      name: "CTO",
+      role: "engineer",
+      status: "active",
+      adapterType: "claude_local",
+      adapterConfig: {},
+      runtimeConfig: {},
+      permissions: {},
+    });
+
+    await db.insert(issues).values([
+      { id: openIssueId, companyId, title: "Confirm plan", status: "in_review", identifier: "KIN-1", issueNumber: 1 },
+      { id: questionIssueId, companyId, title: "Answer question", status: "todo", identifier: "KIN-2", issueNumber: 2 },
+      { id: doneIssueId, companyId, title: "Closed work", status: "done", identifier: "KIN-3", issueNumber: 3 },
+      {
+        id: hiddenIssueId,
+        companyId,
+        title: "Hidden work",
+        status: "todo",
+        identifier: "KIN-4",
+        issueNumber: 4,
+        hiddenAt: now,
+      },
+    ]);
+
+    await db.insert(issueThreadInteractions).values([
+      {
+        id: confirmationId,
+        companyId,
+        issueId: openIssueId,
+        kind: "request_confirmation",
+        status: "pending",
+        continuationPolicy: "wake_assignee",
+        title: "Plan approval",
+        summary: "Approve the Better Actions plan",
+        createdByAgentId: agentId,
+        payload: confirmationPayload({
+          type: "issue_document",
+          key: "plan",
+          revisionId,
+          revisionNumber: 2,
+        }),
+        createdAt: confirmationCreatedAt,
+        updatedAt: confirmationCreatedAt,
+      },
+      {
+        id: questionId,
+        companyId,
+        issueId: questionIssueId,
+        kind: "ask_user_questions",
+        status: "pending",
+        continuationPolicy: "wake_assignee",
+        createdByUserId: "board-user",
+        payload: questionPayload(),
+        createdAt: questionCreatedAt,
+        updatedAt: questionCreatedAt,
+      },
+      // Excluded: already resolved (not pending).
+      {
+        id: acceptedId,
+        companyId,
+        issueId: openIssueId,
+        kind: "request_confirmation",
+        status: "accepted",
+        continuationPolicy: "wake_assignee",
+        createdByAgentId: agentId,
+        payload: confirmationPayload(),
+        createdAt: confirmationCreatedAt,
+        updatedAt: confirmationCreatedAt,
+      },
+      // Excluded: pending but on a terminal (done) issue.
+      {
+        id: doneIssueInteractionId,
+        companyId,
+        issueId: doneIssueId,
+        kind: "request_confirmation",
+        status: "pending",
+        continuationPolicy: "wake_assignee",
+        createdByAgentId: agentId,
+        payload: confirmationPayload(),
+        createdAt: confirmationCreatedAt,
+        updatedAt: confirmationCreatedAt,
+      },
+      // Excluded: pending but on a hidden issue.
+      {
+        id: hiddenIssueInteractionId,
+        companyId,
+        issueId: hiddenIssueId,
+        kind: "request_confirmation",
+        status: "pending",
+        continuationPolicy: "wake_assignee",
+        createdByAgentId: agentId,
+        payload: confirmationPayload(),
+        createdAt: confirmationCreatedAt,
+        updatedAt: confirmationCreatedAt,
+      },
+    ]);
+
+    const pending = await svc.listPendingForCompany(companyId, { now });
+
+    expect(pending.map((p) => p.interaction.id)).toEqual([confirmationId, questionId]);
+
+    const [confirmation, question] = pending;
+
+    // Plan-bound confirmation: full context + document target + requesting agent + age.
+    expect(confirmation.anchor).toBe(`interaction-${confirmationId}`);
+    expect(confirmation.issue).toEqual({
+      id: openIssueId,
+      identifier: "KIN-1",
+      title: "Confirm plan",
+      status: "in_review",
+    });
+    expect(confirmation.requestedByAgent).toEqual({ id: agentId, name: "CTO" });
+    expect(confirmation.requestedByUserId).toBeNull();
+    expect(confirmation.target).toEqual({
+      type: "issue_document",
+      key: "plan",
+      revisionId,
+      revisionNumber: 2,
+    });
+    expect(confirmation.ageSeconds).toBe(3600);
+    expect(confirmation.interaction.kind).toBe("request_confirmation");
+
+    // Question: no document target, created by a board user (no requesting agent).
+    expect(question.anchor).toBe(`interaction-${questionId}`);
+    expect(question.target).toBeNull();
+    expect(question.requestedByAgent).toBeNull();
+    expect(question.requestedByUserId).toBe("board-user");
+    expect(question.ageSeconds).toBe(1800);
+  });
+
+  it("returns an empty list when the company has no pending interactions", async () => {
+    const companyId = randomUUID();
+    await db.insert(companies).values({
+      id: companyId,
+      name: "Empty Co",
+      issuePrefix: "EMP",
+      requireBoardApprovalForNewAgents: false,
+    });
+
+    expect(await svc.listPendingForCompany(companyId, { now: new Date() })).toEqual([]);
+  });
+});
