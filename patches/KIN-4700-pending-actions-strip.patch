diff --git a/ui/src/components/PendingActionsStrip.tsx b/ui/src/components/PendingActionsStrip.tsx
new file mode 100644
index 0000000..0614b66
--- /dev/null
+++ b/ui/src/components/PendingActionsStrip.tsx
@@ -0,0 +1,135 @@
+import { useCallback, useMemo, useState } from "react";
+import type {
+  Agent,
+  IssueThreadInteraction,
+  PendingInteraction,
+} from "@paperclipai/shared";
+import { IssueGroupHeader } from "./IssueGroupHeader";
+import {
+  DecisionInboxRow,
+  type DecisionRowActions,
+} from "./DecisionsInbox";
+
+/**
+ * Phase 2 of Better Actions (KIN-4700): a pinned "Pending actions" strip rendered
+ * above the comment thread on the issue detail page whenever the issue has pending
+ * interactions awaiting a response — so a decision never hides somewhere in the
+ * scrollback.
+ *
+ * It deliberately reuses the Phase 1 {@link DecisionInboxRow}: plain yes/no
+ * confirmations resolve inline (same accept / reject affordances as the inbox),
+ * and everything richer (questions, plan-bound confirmations, checkbox selections,
+ * suggested tasks) routes to the full interaction card already in the thread via
+ * its `#interaction-<id>` anchor — no forked card, single source of truth.
+ *
+ * Resolution flows through the issue page's own optimistic accept / reject
+ * handlers (passed in as {@link onAccept} / {@link onReject}), so resolving on the
+ * strip behaves exactly like resolving on the card itself.
+ */
+export function PendingActionsStrip({
+  interactions,
+  onAccept,
+  onReject,
+  onJump,
+  agentMap,
+  userLabelMap,
+}: {
+  interactions: IssueThreadInteraction[];
+  onAccept: (interaction: IssueThreadInteraction) => Promise<unknown>;
+  onReject: (interaction: IssueThreadInteraction, reason?: string) => Promise<unknown>;
+  /** Scroll to / deep-link the full interaction card for `interaction-<id>`. */
+  onJump: (anchor: string) => void;
+  agentMap?: Map<string, Agent>;
+  userLabelMap?: ReadonlyMap<string, string> | null;
+}) {
+  const [collapsed, setCollapsed] = useState(false);
+
+  // Only interactions still awaiting a response; oldest-first (FIFO) so nothing
+  // starves and the strip order is stable across re-renders.
+  const ordered = useMemo(
+    () =>
+      interactions
+        .filter((interaction) => interaction.status === "pending")
+        .sort((a, b) => {
+          const at = new Date(a.createdAt).getTime();
+          const bt = new Date(b.createdAt).getTime();
+          return at - bt;
+        }),
+    [interactions],
+  );
+
+  // Adapt raw thread interactions into the PendingInteraction shape the shared row
+  // expects. The issue identifier chip is suppressed (we are already on the issue);
+  // `target` only needs populating for plain confirmations, which is all the row's
+  // inline-vs-jump decision inspects.
+  const pendings = useMemo<PendingInteraction[]>(
+    () =>
+      ordered.map((interaction) => {
+        const agentId = interaction.createdByAgentId ?? null;
+        const agent = agentId ? agentMap?.get(agentId) : null;
+        return {
+          interaction,
+          anchor: `interaction-${interaction.id}`,
+          issue: { id: interaction.issueId, identifier: null, title: "", status: "" },
+          requestedByAgent: agent ? { id: agent.id, name: agent.name } : null,
+          requestedByUserId: interaction.createdByUserId ?? null,
+          ageSeconds: 0,
+          target:
+            interaction.kind === "request_confirmation"
+              ? interaction.payload.target ?? null
+              : null,
+        } satisfies PendingInteraction;
+      }),
+    [ordered, agentMap],
+  );
+
+  const actions = useMemo<DecisionRowActions>(
+    () => ({
+      accept: (interaction) => onAccept(interaction),
+      reject: (interaction, reason) => onReject(interaction, reason),
+    }),
+    [onAccept, onReject],
+  );
+
+  const handleOpen = useCallback(
+    (pending: PendingInteraction) => onJump(pending.anchor),
+    [onJump],
+  );
+
+  if (pendings.length === 0) return null;
+
+  return (
+    <div
+      className="overflow-hidden rounded-xl border border-border border-l-2 border-l-sky-500/70 bg-card"
+      data-testid="pending-actions-strip"
+    >
+      <div className="px-3 sm:px-4">
+        <IssueGroupHeader
+          label={`Pending actions · ${pendings.length}`}
+          collapsible
+          collapsed={collapsed}
+          onToggle={() => setCollapsed((value) => !value)}
+          trailing={
+            <span className="text-xs font-normal normal-case tracking-normal text-muted-foreground">
+              Needs your response
+            </span>
+          }
+        />
+      </div>
+      {!collapsed ? (
+        <div>
+          {pendings.map((pending) => (
+            <DecisionInboxRow
+              key={pending.interaction.id}
+              pending={pending}
+              actions={actions}
+              userLabelMap={userLabelMap}
+              onOpenQuickView={handleOpen}
+              seeMoreLabel="Jump to"
+            />
+          ))}
+        </div>
+      ) : null}
+    </div>
+  );
+}
